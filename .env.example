# ============================================================
# Converclick CRM — Variables de Entorno
# Copiar a .env y completar con los valores reales
# ============================================================

# Aplicación
APP_NAME="Converclick CRM"
APP_URL="https://tudominio.com"
APP_KEY="cambia_esto_por_una_cadena_aleatoria_de_32_chars"
APP_ENV="production"
APP_DEBUG="false"
TIMEZONE="America/Santiago"

# Base de Datos
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="nombre_de_tu_base_de_datos"
DB_USER="usuario_db"
DB_PASS="contraseña_db"
DB_CHARSET="utf8mb4"

# Seguridad de Webhooks
MAUTIC_WEBHOOK_SECRET="token_secreto_mautic_cambiar"
UAZAPI_WEBHOOK_SECRET="token_secreto_uazapi_cambiar"

# Sesión
SESSION_NAME="converclick_crm"
SESSION_LIFETIME="7200"
